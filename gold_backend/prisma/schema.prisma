generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String?
  action    String
  details   Json?
  ipAddress String?
  createdAt DateTime @default(now())
  user      User?    @relation(fields: [userId], references: [id], map: "AuditLog_userId_fkey")

  @@index([userId], map: "AuditLog_userId_fkey")
  @@map("auditlog")
}

model Category {
  id        String    @id @default(uuid())
  name      String    @unique(map: "Category_name_key")
  slug      String    @unique(map: "Category_slug_key")
  imageUrl  String?
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  products  Product[]

  @@index([isActive], map: "Category_isActive_idx")
  @@map("category")
}

model GoldPrice {
  id        String   @id @default(uuid())
  sellPrice Decimal  @db.Decimal(15, 2)
  buyPrice  Decimal  @db.Decimal(15, 2)
  timestamp DateTime @default(now())

  @@index([timestamp], map: "GoldPrice_timestamp_idx")
  @@map("goldprice")
}

model Order {
  id                  String      @id @default(uuid())
  userId              String
  productId           String
  quantity            Int         @default(1)
  weight              Decimal?    @db.Decimal(10, 3)
  amount              Decimal     @db.Decimal(15, 2)
  gst                 Decimal     @db.Decimal(15, 2)
  total               Decimal     @db.Decimal(15, 2)
  status              OrderStatus @default(PAYMENT_PENDING)
  paymentId           String?     @unique(map: "Order_paymentId_key")
  paymentStatus       String?
  deliveryDate        DateTime?
  goldPriceAtPurchase Decimal?    @db.Decimal(15, 2)
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt
  referralCode        String?
  invoiceNo           String?     @unique(map: "Order_invoiceNo_key")
  invoiceUrl          String?
  product             Product     @relation(fields: [productId], references: [id], map: "Order_productId_fkey")
  user                User        @relation(fields: [userId], references: [id], map: "Order_userId_fkey")
  payments            Payment[]
  statusHistory       OrderStatusHistory[]

  @@index([productId], map: "Order_productId_fkey")
  @@index([status], map: "Order_status_idx")
  @@index([userId], map: "Order_userId_idx")
  @@map("order")
}

model Otp {
  id        String   @id @default(uuid())
  phone     String   @unique(map: "Otp_phone_key")
  code      String
  verified  Boolean  @default(false)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@map("otp")
}

model Product {
  id            String    @id @default(uuid())
  name          String
  description   String?   @db.Text
  weight        Decimal   @db.Decimal(10, 3)
  purity        String    @default("24K")
  imageUrl      String?
  stock         Int       @default(0)
  readyStock    Int       @default(0)
  isActive      Boolean   @default(true)
  categoryId    String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  fixedPrice    Decimal   @default(0.00) @db.Decimal(15, 2)
  makingCharges Decimal   @default(0.00) @db.Decimal(15, 2)
  isPremium     Boolean   @default(false)
  isPromoted    Boolean   @default(false)
  orders        Order[]
  category      Category? @relation(fields: [categoryId], references: [id], map: "Product_categoryId_fkey")

  @@index([categoryId], map: "Product_categoryId_idx")
  @@index([isActive], map: "Product_isActive_idx")
  @@index([isPremium], map: "Product_isPremium_idx")
  @@map("product")
}

model Setting {
  id          String   @id @default(uuid())
  key         String   @unique(map: "Setting_key_key")
  value       String
  description String?
  updatedAt   DateTime @updatedAt

  @@map("setting")
}

model Transaction {
  id          String          @id @default(uuid())
  userId      String
  type        TransactionType
  amount      Decimal         @db.Decimal(15, 2)
  description String?
  status      String          @default("COMPLETED")
  createdAt   DateTime        @default(now())
  invoiceNo   String?         @unique(map: "Transaction_invoiceNo_key")
  user        User            @relation(fields: [userId], references: [id], map: "Transaction_userId_fkey")

  @@index([type], map: "Transaction_type_idx")
  @@index([userId], map: "Transaction_userId_idx")
  @@map("transaction")
}

model User {
  id                               String              @id @default(uuid())
  name                             String
  email                            String              @unique(map: "User_email_key")
  phone                            String              @unique(map: "User_phone_key")
  password                         String
  role                             UserRole            @default(CUSTOMER)
  kycStatus                        KycStatus           @default(PENDING)
  aadharNo                         String?
  panNo                            String?
  address                          String?
  photo                            String?
  referrerId                       String?
  staffId                          String?
  createdAt                        DateTime            @default(now())
  updatedAt                        DateTime            @updatedAt
  referralCode                     String              @unique(map: "User_referralCode_key")
  bankAccountNo                    String?
  bankHolderName                   String?
  bankIfsc                         String?
  bankName                         String?
  bankStatus                       BankStatus          @default(PENDING)
  auditLogs                        AuditLog[]
  orders                           Order[]
  transactions                     Transaction[]
  user_user_referrerIdTouser       User?               @relation("user_referrerIdTouser", fields: [referrerId], references: [id], map: "User_referrerId_fkey")
  other_user_user_referrerIdTouser User[]              @relation("user_referrerIdTouser")
  user_user_staffIdTouser          User?               @relation("user_staffIdTouser", fields: [staffId], references: [id], map: "User_staffId_fkey")
  other_user_user_staffIdTouser    User[]              @relation("user_staffIdTouser")
  wallet                           Wallet?
  withdrawalRequests               WithdrawalRequest[]
  notifications                    Notification[]
  fcmToken                         String?             @db.VarChar(255)

  @@index([phone], map: "User_phone_idx")
  @@index([referrerId], map: "User_referrerId_fkey")
  @@index([role], map: "User_role_idx")
  @@index([staffId], map: "User_staffId_fkey")
  @@map("user")
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  title     String
  body      String
  type      String   @default("GENERAL")
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("notification")
}

model Wallet {
  id              String   @id @default(uuid())
  userId          String   @unique(map: "Wallet_userId_key")
  balance         Decimal  @default(0.00) @db.Decimal(15, 2)
  goldAdvance     Decimal  @default(0.00) @db.Decimal(15, 2)
  referralRewards Decimal  @default(0.00) @db.Decimal(15, 2)
  updatedAt       DateTime @updatedAt
  user            User     @relation(fields: [userId], references: [id], map: "Wallet_userId_fkey")

  @@map("wallet")
}

model Payment {
  id                String   @id @default(uuid())
  orderId           String
  razorpayOrderId   String   @unique
  razorpayPaymentId String?  @unique
  razorpaySignature String?
  amount            Decimal  @db.Decimal(15, 2)
  currency          String   @default("INR")
  status            String   @default("PENDING")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  order             Order    @relation(fields: [orderId], references: [id])

  @@index([orderId], map: "payment_orderId_fkey")
  @@map("payment")
}

model AppConfig {
  key   String @id
  value String

  @@map("app_config")
}

model WithdrawalRequest {
  id          String   @id @default(uuid())
  userId      String
  amount      Decimal  @db.Decimal(15, 2)
  status      String   @default("PENDING")
  bankDetails Json?
  adminNotes  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id])

  @@index([userId], map: "WithdrawalRequest_userId_idx")
  @@map("withdrawal_request")
}

enum UserRole {
  ADMIN
  CUSTOMER
  STAFF

  @@map("user_role")
}

enum KycStatus {
  PENDING
  VERIFIED
  REJECTED

  @@map("user_kycStatus")
}

enum BankStatus {
  PENDING
  VERIFIED
  REJECTED

  @@map("user_bankStatus")
}

enum TransactionType {
  DEPOSIT
  PURCHASE
  WITHDRAWAL
  CREDIT
  REFERRAL
  REWARD
  REFERRAL_REWARD
  SELL_BACK

  @@map("transaction_type")
}

enum OrderStatus {
  PAYMENT_PENDING
  PAYMENT_SUCCESSFUL
  ORDER_CONFIRMED
  PROCESSING
  QUALITY_CHECKING
  READY_FOR_PICKUP
  PICKED_UP
  BUYBACK
  CANCELLED
  REFUNDED

  @@map("order_status")
}

model OrderStatusHistory {
  id        String      @id @default(uuid())
  orderId   String
  status    OrderStatus
  notes     String?     @db.Text
  createdAt DateTime    @default(now())
  order     Order       @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@map("order_status_history")
}
